@{
    ViewData["Title"] = ViewData["Title"] ?? "Projects";
    var projects = ViewData["ProjectList"] as List<(string Title, string Description, string[] Tags, string RepoUrl)>
                    ?? new List<(string Title, string Description, string[] Tags, string RepoUrl)>();
}

<section id="projects" class="py-5 my-4">
    <h2 class="mb-4 fw-bold">@ViewData["SectionHeading"]</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var project in projects)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="~/images/briefing.png" class="flex-shrink-0 me-3 mt-3 ms-3" alt="Project Icon" style="width: 25px; height: 25px; object-fit: contain;">

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@project.Title</h5>
                        <p class="card-text flex-grow-1">@project.Description</p>
                        <div class="mb-3">
                            @foreach (var tag in project.Tags)
                            {
                                <span class="badge bg-secondary">@tag</span>
                            }
                        </div>
                        <a href="@project.RepoUrl" target="_blank" class="btn btn-outline-primary btn-sm mt-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
