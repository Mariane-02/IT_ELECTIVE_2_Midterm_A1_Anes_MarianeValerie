@{
    ViewData["Title"] = ViewData["Title"] ?? "Home";
}

<section id="home" class="hero-section">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left Side -->
            <div class="col-lg-6">

                <span class="badge bg-primary mb-2 px-3 py-2">
                    @ViewData["Badge"]
                </span>

                <h5 class="text-primary fw-bold mb-1 mt-3">
                    @ViewData["Greeting"]
                </h5>

                <h1 class="display-4 fw-bold mt-1 mb-2">
                    @ViewData["FullName"]
                </h1>

                <h3 class="text-secondary mb-3">
                    @ViewData["RoleTitle"]
                </h3>

                <p class="lead text-muted">
                    @ViewData["Intro"]
                </p>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Projects" class="btn btn-primary btn-lg me-2">
                        <i class="bi bi-folder-fill me-2"></i>View Projects
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-envelope-fill me-2"></i>Contact Me
                    </a>
                </div>

            </div>

            <!-- Right Side -->
            <div class="col-lg-6 text-center mt-5 mt-lg-0">

                <img src="~/images/media.jpg"
                     class="hero-image"
                     alt="@ViewData["FullName"]">

            </div>

        </div>
    </div>
</section>
